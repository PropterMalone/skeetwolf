# Bluesky bot account credentials (app password must have DM permission)
BSKY_IDENTIFIER=
BSKY_PASSWORD=

# Set to 1 to send real DMs via Bluesky chat API (default: console logging)
LIVE_DMS=1

# Feed generator
FEED_PORT=3001
FEED_HOSTNAME=
FEED_PUBLISHER_DID=

# Labeler (optional — labels game posts for non-player filtering)
LABELER_DID=
LABELER_SIGNING_KEY=
LABELER_PORT=3002
