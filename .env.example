# Bluesky bot account credentials (app password must have DM permission)
BSKY_IDENTIFIER=
BSKY_PASSWORD=

# Set to 1 to send real DMs via Bluesky chat API (default: console logging)
LIVE_DMS=1

# Feed generator
FEED_PORT=3001
FEED_HOSTNAME=
FEED_PUBLISHER_DID=

# Dashboard
DASHBOARD_PORT=3003

# FAQ URL included in role DMs (optional — omit to skip)
FAQ_URL=

# Operator handle — @mentioned in day threads so they can reply through threadgate (optional)
OPERATOR_HANDLE=

# Labeler (optional — propter-labeler service for game post filtering)
LABELER_URL=http://labeler:4100
LABELER_SECRET=
